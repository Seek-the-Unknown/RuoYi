<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.BooksInformationMapper">
    
    <resultMap type="BooksInformation" id="BooksInformationResult">
        <result property="bookId"    column="book_id"    />
        <result property="bookName"    column="book_name"    />
        <result property="bookAuthor"    column="book_author"    />
        <result property="bookImage"    column="book_image"    />
        <result property="typeId"    column="type_id"    />
    </resultMap>

    <sql id="selectBooksInformationVo">
        select book_id, book_name, book_author, book_image, type_id from books_information
    </sql>

    <select id="selectBooksInformationList" parameterType="BooksInformation" resultMap="BooksInformationResult">
        <include refid="selectBooksInformationVo"/>
        <where>  
            <if test="bookName != null  and bookName != ''"> and book_name like concat('%', #{bookName}, '%')</if>
            <if test="bookAuthor != null  and bookAuthor != ''"> and book_author = #{bookAuthor}</if>
            <if test="bookImage != null  and bookImage != ''"> and book_image = #{bookImage}</if>
            <if test="typeId != null "> and type_id = #{typeId}</if>
        </where>
    </select>
    
    <select id="selectBooksInformationByBookId" parameterType="Long" resultMap="BooksInformationResult">
        <include refid="selectBooksInformationVo"/>
        where book_id = #{bookId}
    </select>

    <insert id="insertBooksInformation" parameterType="BooksInformation" useGeneratedKeys="true" keyProperty="bookId">
        insert into books_information
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="bookName != null and bookName != ''">book_name,</if>
            <if test="bookAuthor != null and bookAuthor != ''">book_author,</if>
            <if test="bookImage != null">book_image,</if>
            <if test="typeId != null">type_id,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="bookName != null and bookName != ''">#{bookName},</if>
            <if test="bookAuthor != null and bookAuthor != ''">#{bookAuthor},</if>
            <if test="bookImage != null">#{bookImage},</if>
            <if test="typeId != null">#{typeId},</if>
         </trim>
    </insert>

    <update id="updateBooksInformation" parameterType="BooksInformation">
        update books_information
        <trim prefix="SET" suffixOverrides=",">
            <if test="bookName != null and bookName != ''">book_name = #{bookName},</if>
            <if test="bookAuthor != null and bookAuthor != ''">book_author = #{bookAuthor},</if>
            <if test="bookImage != null">book_image = #{bookImage},</if>
            <if test="typeId != null">type_id = #{typeId},</if>
        </trim>
        where book_id = #{bookId}
    </update>

    <delete id="deleteBooksInformationByBookId" parameterType="Long">
        delete from books_information where book_id = #{bookId}
    </delete>

    <delete id="deleteBooksInformationByBookIds" parameterType="String">
        delete from books_information where book_id in 
        <foreach item="bookId" collection="array" open="(" separator="," close=")">
            #{bookId}
        </foreach>
    </delete>
</mapper>